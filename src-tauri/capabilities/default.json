{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-create",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:default",
    "core:webview:allow-create-webview-window",
    "shell:allow-execute",
    "shell:allow-kill",
    "allow-open-native-chart",
    "allow-greet",
    "allow-get-bars",
    "allow-get-options-chain",
    "allow-drawings-load-all",
    "allow-drawings-load-symbol",
    "allow-drawings-save",
    "allow-drawings-update-points",
    "allow-drawings-update-style",
    "allow-drawings-remove",
    "allow-drawings-clear",
    "allow-groups-load-all",
    "allow-groups-save",
    "allow-groups-remove",
    "allow-groups-update-style",
    "allow-drawings-apply-group-style",
    "allow-ib-ws-send"
  ]
}
