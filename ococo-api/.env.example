# ococo-api required credentials. Copy to .env and fill in real values.
# .env itself MUST stay gitignored.
POSTGRES_PASSWORD=
REDIS_PASSWORD=
INFLUXDB_TOKEN=

# Hosts default to homelab values; override only if running elsewhere.
# POSTGRES_HOST=192.168.1.143
# POSTGRES_PORT=5432
# POSTGRES_DB=ococo
# POSTGRES_USER=postgres
# REDIS_HOST=192.168.1.89
# REDIS_PORT=6379
# INFLUXDB_URL=http://192.168.1.67:8086
# INFLUXDB_ORG=homelab
